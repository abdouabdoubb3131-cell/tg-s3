# ===== 必填项 (仅需 2 项) =====

# Telegram Bot Token (从 @BotFather 获取)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram 群组 ID (Bot 必须是管理员, 如 -1001234567890)
DEFAULT_CHAT_ID=-1001234567890

# ===== Cloudflare 配置 =====

# Cloudflare API Token (Docker 部署必填, 本地部署可用 wrangler login 代替)
# 创建: https://dash.cloudflare.com/profile/api-tokens
# 最低权限: Workers Scripts:Edit, D1:Edit, R2:Edit, Account Settings:Read
# 如需 tunnel: 额外需要 Cloudflare Tunnel:Edit, DNS:Edit
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID (可选, 多账户时需要; 单账户自动检测)
CF_ACCOUNT_ID=

# Worker 自定义域名 (可选, 留空则使用 workers.dev 子域)
CF_CUSTOM_DOMAIN=

# ===== Cloudflare Tunnel (可选, 推荐用于 Docker 部署) =====
# 有 CF_CUSTOM_DOMAIN 时 deploy.sh 会自动创建 tunnel
# 也可在 CF Dashboard > Zero Trust > Tunnels 手动创建后填入
CF_TUNNEL_TOKEN=

# ===== VPS 手动部署 (非 Docker 模式, 通过 SSH 部署到远程 VPS) =====
# Docker 部署不需要以下配置

# VPS_SSH=root@1.2.3.4
# VPS_DEPLOY_DIR=/opt/tg-s3
# VPS_PORT=3000
# VPS_URL=https://vps.example.com:3000

# ===== 自动生成项 (通常无需手动设置) =====
# VPS_SECRET 由 deploy.sh 自动生成
# S3 凭据在 D1 中自动创建, 通过 Mini App Keys 标签页管理
# Webhook secret 从 TG_BOT_TOKEN 自动派生

# VPS_SECRET=           # Worker <-> Processor 共享密钥 (自动生成)
